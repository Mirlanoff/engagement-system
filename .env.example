# ================================================================
#  STUDENT ENGAGEMENT SYSTEM — Environment Variables
#  Скопируй в .env и заполни все значения перед запуском
# ================================================================

# ── Приложение ──────────────────────────────────────────────────
APP_NAME="EngagementMonitor"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://your-school-server.local
SEED_DEMO_DATA=false

# ВАЖНО: сгенерируй через: php artisan key:generate --show
APP_KEY=base64:REPLACE_WITH_GENERATED_KEY

# ── База данных PostgreSQL ───────────────────────────────────────
DB_DATABASE=engagement_db
DB_USERNAME=engage_user
# Минимум 20 символов, случайный
DB_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# ── Redis ────────────────────────────────────────────────────────
REDIS_PASSWORD=REPLACE_WITH_REDIS_PASSWORD

# ── WebSocket (Soketi) ───────────────────────────────────────────
PUSHER_APP_ID=engagement_app
PUSHER_APP_KEY=engagement_key_32chars_here
PUSHER_APP_SECRET=REPLACE_WITH_PUSHER_SECRET

# ── ML Сервис ────────────────────────────────────────────────────
# Секрет для внутреннего API между Laravel и ML сервисом
ML_SERVICE_SECRET=REPLACE_WITH_ML_SECRET_TOKEN

# Интервал захвата кадров (секунды)
FRAME_INTERVAL=10

# Локальная USB webcam для dev/test: rtsp_url в classroom camera_config должен быть "0"
WEBCAM_DEVICE=/dev/video0

# Максимум воркеров Celery для обработки лиц
ML_MAX_WORKERS=4

# Бэкенд моделей: opencv | mediapipe | deepface
ML_MODEL_BACKEND=mediapipe
ML_EXPOSE_DOCS=false

# ── AI Рекомендации (Claude API) ─────────────────────────────────
CLAUDE_API_KEY=

# ── Мониторинг ───────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=REPLACE_WITH_GRAFANA_PASSWORD

FLOWER_USER=admin
FLOWER_PASSWORD=REPLACE_WITH_FLOWER_PASSWORD

# ── Логирование ──────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Debug (только для разработки) ────────────────────────────────
SOKETI_DEBUG=0
